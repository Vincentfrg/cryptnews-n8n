    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\n\nconst htmlContent = content\n  .replace(/\\*\\*(.*?)\\*\\*/g, '<strong style=\"color:#111111;\">$1</strong>')\n  .replace(/\\n\\n/g, '</p><p style=\"margin:0 0 14px;line-height:1.8;color:#333333;font-size:14px;\">')\n  .replace(/\\n/g, '<br>');\n\nconst date = new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n\nconst html = `<!DOCTYPE html>\n<html>\n<head><meta charset=\"UTF-8\"></head>\n<body style=\"margin:0;padding:0;background:#f5f5f5;font-family:Arial,sans-serif;\">\n<div style=\"max-width:600px;margin:32px auto;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e0e0e0;\">\n\n  <!-- HEADER -->\n  <div style=\"background:#111111;padding:28px 32px;\">\n    <p style=\"margin:0 0 6px;font-size:11px;color:#00ff9d;font-family:monospace;letter-spacing:2px;\">~/cryptnews</p>\n    <h1 style=\"margin:0;font-size:20px;color:#ffffff;font-weight:700;\">🚀 Crypto Daily Report</h1>\n    <p style=\"margin:6px 0 0;font-size:12px;color:#888888;font-family:monospace;\">${date}</p>\n  </div>\n\n  <!-- CONTENU -->\n  <div style=\"padding:28px 32px;\">\n    <p style=\"margin:0 0 14px;line-height:1.8;color:#333333;font-size:14px;\">${htmlContent}</p>\n  </div>\n\n  <!-- SOURCES -->\n  <div style=\"padding:20px 32px;background:#f9f9f9;border-top:1px solid #e0e0e0;\">\n    <p style=\"margin:0 0 12px;font-size:11px;color:#999999;font-family:monospace;letter-spacing:1px;\">SOURCES</p>\n    <div style=\"display:flex;flex-wrap:wrap;gap:8px;\">\n      <a href=\"https://www.coingecko.com\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">CoinGecko</a>\n      <a href=\"https://coinmarketcap.com\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">CoinMarketCap</a>\n      <a href=\"https://www.binance.com/fr/markets/overview\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">Binance</a>\n      <a href=\"https://www.reuters.com/technology/cryptocurrency\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">Reuters Crypto</a>\n      <a href=\"https://cryptopanic.com\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">CryptoPanic</a>\n      <a href=\"https://minepi.com\" style=\"padding:5px 10px;border:1px solid #e0e0e0;border-radius:4px;color:#111111;font-size:12px;background:#ffffff;text-decoration:none;\">Pi Network</a>\n    </div>\n  </div>\n\n  <!-- FOOTER -->\n  <div style=\"padding:16px 32px;background:#111111;text-align:center;\">\n    <p style=\"margin:0;font-size:11px;color:#555555;font-family:monospace;\">generated by n8n · groq/llama-3.3 · coingecko — <a href=\"https://vincentfrg.vercel.app\" style=\"color:#00ff9d;text-decoration:none;\">vincentfrg.vercel.app</a></p>\n  </div>\n\n</div>\n</body>\n</html>`;\n\nreturn [{ json: { emailContent: html } }];"
      },
