    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst top10 = items\n  .filter(item => \n    item.json.current_price !== null && \n    item.json.current_price !== undefined &&\n    item.json.price_change_percentage_24h !== null &&\n    item.json.price_change_percentage_24h !== undefined &&\n    typeof item.json.price_change_percentage_24h === 'number' &&\n    !item.json.prices\n  )\n  .map(item => {\n    const change7d = item.json.price_change_percentage_7d_in_currency;\n    const change7dStr = change7d !== undefined && change7d !== null ? ` | 7j: ${change7d.toFixed(2)}%` : '';\n    return `${item.json.name} (${item.json.symbol.toUpperCase()}): ${item.json.current_price}EUR | 24h: ${item.json.price_change_percentage_24h.toFixed(2)}%${change7dStr}`;\n  });\n\nconst piItem = items.find(item => item.json.prices);\nconst piPrices = piItem.json.prices;\nconst piFirst = piPrices[0][1];\nconst piLast = piPrices[piPrices.length - 1][1];\nconst piChange = ((piLast - piFirst) / piFirst * 100).toFixed(2);\nconst piSummary = `Pi Network (PI): ${piLast.toFixed(4)}EUR | 48h: ${piChange}%`;\n\nconst report = `TOP 10 (par volume): ${top10.join(' || ')} || ${piSummary}`;\nconst prompt = `Tu es un analyste crypto expert. Données marché : ${report}. Génère un rapport détaillé en français avec : 1) Tendance générale du marché 2) Analyse des cryptos les plus significatives 3) Analyse Pi Network 4) Perspectives à court terme. Ne cite aucune source dans le texte. Rédige uniquement l'analyse, sans références entre parenthèses ni numéros de sources.`;\n\nreturn [{ json: { report, prompt } }];"
      },
